{
  "name": "starvein",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "homepage": "https://starvein.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lostspezi/starvein.git"
  },
  "bugs": {
    "url": "https://github.com/lostspezi/starvein/issues"
  },
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:jsdoc": "eslint --config eslint.jsdoc.config.mjs --quiet .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "e2e:server": "next build && next start -p 3100",
    "seed": "tsx --env-file=.env.local scripts/seed.ts",
    "sync:uex": "tsx --env-file=.env.local scripts/sync-uex.ts",
    "sync:wiki": "tsx --env-file=.env.local scripts/sync-wiki.ts",
    "promote": "tsx --env-file=.env.local scripts/promote.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix",
    "*.{ts,tsx,json,css,md}": "prettier --write"
  },
  "dependencies": {
    "@starvein/shared": "workspace:*",
    "@tiptap/core": "^3.28.0",
    "@tiptap/extension-image": "^3.28.0",
    "@tiptap/extension-youtube": "^3.28.0",
    "@tiptap/html": "^3.28.0",
    "@tiptap/markdown": "^3.28.0",
    "@tiptap/pm": "^3.28.0",
    "@tiptap/react": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "better-auth": "^1.6.23",
    "clsx": "^2.1.1",
    "ioredis": "^5.11.1",
    "lucide-react": "^1.23.0",
    "mongodb": "^7.5.0",
    "next": "16.2.10",
    "next-intl": "^4.13.1",
    "nuqs": "^2.9.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.2",
    "sanitize-html": "^2.17.6",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^63.0.13",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "mongodb-memory-server": "^11.2.0",
    "msw": "^2.15.0",
    "prettier": "^3.9.4",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
