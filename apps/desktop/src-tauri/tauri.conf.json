{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "STARVEIN Companion",
  "version": "0.3.0",
  "identifier": "app.starvein.companion",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "STARVEIN Companion",
        "width": 960,
        "height": 640,
        "minWidth": 640,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNEQjEwRUE0NkM3MTQ2ODQKUldTRVJuRnNwQTZ4UFNhMEYxWWVRdFlxR0hnelQ0Tnl0RVRoUU1RS2hKR0hqTVcwNTZJSnRvQlAK",
      "endpoints": ["https://starvein.app/api/companion/latest.json"]
    }
  }
}
