MONGODB_URI=mongodb://localhost:27017/starvein
REDIS_URL=redis://localhost:6379
UEX_API_BASE_URL=https://api.uexcorp.space/2.0
# Star Citizen Wiki API (Erze, Locations, Vorkommen, Signaturen, Blueprints;
# kein Key nötig) — pnpm sync:wiki
SCWIKI_API_BASE_URL=https://api.star-citizen.wiki
UEX_API_KEY=
SYNC_SECRET=change-me
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=change-me
# Optional: zusätzliche erlaubte Origins (CSRF/Open-Redirect), kommasepariert.
# Der Origin von BETTER_AUTH_URL ist immer erlaubt. Wildcards möglich, z. B.
# https://*.starvein.app
BETTER_AUTH_TRUSTED_ORIGINS=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Admin-Dashboard: komma-separierte Discord-User-IDs mit Zugriff auf
# /admin/dashboard (Registrierungs- & SEO-Statistiken). Leer ⇒ niemand.
ADMIN_DISCORD_IDS=
# SEO-Dashboard via Cloudflare Analytics (alles optional — fehlt es, zeigt das
# Panel "nicht konfiguriert" statt zu crashen).
# API-Token mit Berechtigung "Analytics:Read" (Account). Account-ID + RUM-Site-Tag
# adressieren das Web-Analytics-Dataset (Länder, Referrer, Top-Seiten, Page-Views).
# Zone-ID optional (für spätere zonenweite httpRequests-Auswertung).
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_RUM_SITE_TAG=
CLOUDFLARE_ZONE_ID=
# Public: Token des cookielosen Cloudflare-Web-Analytics-Beacons (Client).
NEXT_PUBLIC_CF_BEACON_TOKEN=
# Search-Console-Verifizierung (Meta-Tag). Public, da im HTML sichtbar.
# Google: Token aus Search Console → "HTML-Tag"-Methode (nur der content-Wert).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Bing/Yandex: content-Wert des msvalidate.01-Tags aus Bing Webmaster Tools.
NEXT_PUBLIC_BING_SITE_VERIFICATION=
# IndexNow-Key (Bing/Yandex/DuckDuckGo Sofort-Ping nach dem Wiki-Sync).
# Beliebiger Hex-String (8–128 Zeichen). Der Ownership-Nachweis läuft über
# /indexnow-key.txt (Route-Handler liefert den Key). Leer ⇒ Ping wird
# übersprungen. Denselben Key in Bing Webmaster Tools hinterlegen.
INDEXNOW_KEY=
