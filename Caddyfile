# TLS besorgt Caddy automatisch per Let's Encrypt (HTTP-01),
# sobald der DNS-A-Record von starvein.app auf den VPS zeigt.
starvein.app {
	reverse_proxy app:3000
	encode gzip zstd

	# Security-Header am TLS-Terminator (Defense in Depth zu next.config.ts).
	# HSTS gehört hierher, weil Caddy TLS terminiert; CSP/X-Frame-Options setzt
	# die App pro Response.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		# Server-Version nicht preisgeben
		-Server
	}
}

www.starvein.app {
	redir https://starvein.app{uri} permanent
}
